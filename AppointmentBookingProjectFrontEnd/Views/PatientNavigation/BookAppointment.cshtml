@using AppointmentBookingProjectFrontEnd.Models.Dtos
@model List<AppointmentBookingProjectFrontEnd.Models.Dtos.PhysicianAvailabilityDto>

@{
    ViewData["Title"] = "Book Appointment";
    string? physicianName = Context.Session.GetString("SelectedPhysicianName");
}

<div class="container mt-4">
    <div class="mb-4">
        <a asp-controller="PatientNavigation" asp-action="ChoosePhysician" class="btn btn-secondary mb-3">
            Change Physician
        </a>
        <h2>Book Appointment</h2>
        <p class="text-muted">Booking with: <strong>@physicianName</strong></p>
    </div>

    <h4>Available Times</h4>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            No available times for this physician.
        </div>
    }
    else
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th>Date</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                            <th>Select</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var availability in Model)
                        {
                            <tr>
                                <td>@availability.StartTime?.ToString("yyyy-MM-dd")</td>
                                <td>@availability.StartTime?.ToString("hh:mm tt")</td>
                                <td>@availability.EndTime?.ToString("hh:mm tt")</td>
                                <td>
                                    <button type="button"
                                            class="btn btn-primary btn-sm select-time-btn"
                                            data-id="@availability.Id"
                                            data-start="@availability.StartTime"
                                            data-end="@availability.EndTime">
                                        Select Time
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="alert alert-success d-none" id="selectedTimeDisplay"></div>
    }

    <hr />

    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="card-title mb-4">Appointment Details</h4>

            <form asp-controller="PatientNavigation" asp-action="BookAppointment" method="post">
                <input type="hidden" id="selectedAvailabilityId" name="AvailabilityId" />
                <input type="hidden" id="selectedStartTime" name="BookedTimeStart" />
                <input type="hidden" id="selectedEndTime" name="BookedTimeEnd" />
                <input type="hidden" name="PhysicianId" value="@Context.Session.GetString("SelectedPhysicianId")" />

                <div class="mb-3">
                    <label for="reasonForVisit" class="form-label">Reason for visiting</label>
                    <input type="text" id="reasonForVisit" name="ReasonForVisit" class="form-control" placeholder="Enter reason for visiting" />
                </div>

                <div class="mb-3">
                    <label for="Age" class="form-label">Age</label>
                    <input type="number" id="Age" name="Age" class="form-control" />
                </div>

                <div class="mb-3">
                    <label for="Gender" class="form-label">Gender</label>
                    <select id="Gender" name="Gender" class="form-select">
                        <option value="">-- Select --</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="Height" class="form-label">Height (cm)</label>
                    <input type="number" step="0.1" id="Height" name="Height" class="form-control" />
                </div>

                <div class="mb-3">
                    <label for="Weight" class="form-label">Weight (kg)</label>
                    <input type="number" step="0.1" id="Weight" name="Weight" class="form-control" />
                </div>

                <div class="mb-3">
                    <label for="PhoneNumber" class="form-label">Phone Number</label>
                    <input type="tel" id="PhoneNumber" name="PhoneNumber" class="form-control" />
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-success">Book Appointment</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    let selectedButton = null;

    document.querySelectorAll('.select-time-btn').forEach(button => {
        button.addEventListener('click', function () {
            if (selectedButton && selectedButton !== this) {
                selectedButton.style.display = 'inline';
            }

            document.getElementById('selectedAvailabilityId').value = this.dataset.id;
            document.getElementById('selectedStartTime').value = this.dataset.start;
            document.getElementById('selectedEndTime').value = this.dataset.end;

            const display = document.getElementById('selectedTimeDisplay');
            display.textContent = `Selected Time: ${this.dataset.start} - ${this.dataset.end}`;
            display.classList.remove('d-none');

            this.style.display = 'none';
            selectedButton = this;
        });
    });
</script>