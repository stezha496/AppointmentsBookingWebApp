@model List<AppointmentBookingProjectFrontEnd.Models.Dtos.PhysicianDto>

@{
    ViewData["Title"] = "Choose Physician";
}

<div class="container mt-4">
    <div class="mb-4">
        <a asp-controller="PatientNavigation" asp-action="PatientDashboard" class="btn btn-secondary mb-3">
            Return to Dashboard
        </a>
        <h2>Choose a Physician</h2>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            No physicians available.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th>Name</th>
                            <th>Phone Number</th>
                            <th>Select</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var physician in Model)
                        {
                            <tr>
                                <td>@physician.Name</td>
                                <td>@physician.PhoneNumber</td>
                                <td>
                                    <a asp-controller="PatientNavigation"
                                           asp-action="BookAppointment"
                                           asp-route-physicianId="@physician.PhysicianId"
                                           asp-route-physicianName="@physician.Name"
                                           class="btn btn-primary btn-sm">
                                        Select
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>