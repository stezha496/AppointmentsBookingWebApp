@model List<AppointmentBookingProjectFrontEnd.Models.Dtos.BookingDto>

@{
    ViewData["Title"] = "My Bookings";
}

<div class="container mt-4">
    <div class="mb-4">
        <a asp-controller="PatientNavigation" asp-action="PatientDashboard" class="btn btn-secondary mb-3">
            Return to Dashboard
        </a>
        <h2>My Bookings</h2>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            You have no bookings.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th>Reason For Visit</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Start Time</th>
                            <th>Duration (minutes)</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model)
                        {
                            <tr>
                                <td>@booking.ReasonForVisit</td>
                                <td>
                                    <span class="badge @(booking.Status == "Confirmed" ? "bg-success" :
                                                                                                                                           booking.Status == "Cancelled" ? "bg-danger" :
                                                                                                                                           "bg-warning text-dark")">
                                        @booking.Status
                                    </span>
                                </td>
                                <td>@booking.BookedTimeStart?.ToString("yyyy-MM-dd")</td>
                                <td>@booking.BookedTimeStart?.ToString("hh:mm tt")</td>
                                <td>@booking.BookedTimeDuration</td>
                                <td>@booking.Created.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>