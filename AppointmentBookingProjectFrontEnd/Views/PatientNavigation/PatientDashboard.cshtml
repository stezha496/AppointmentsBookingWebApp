@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2>Patient Dashboard</h2>
        <p class="text-muted">Welcome, <strong>@Context.Session.GetString("UserName")</strong></p>
    </div>

    <div class="row">
        <div class="col-md-4">
            <a asp-controller="PatientNavigation" asp-action="PatientBookings" class="text-decoration-none">
                <div class="card shadow-sm h-100 border-primary">
                    <div class="card-body">
                        <h3 class="card-title text-primary">View My Bookings</h3>
                        <p class="card-text text-muted">View all your current and past appointments</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-controller="PatientNavigation" asp-action="ChoosePhysician" class="text-decoration-none">
                <div class="card shadow-sm h-100 border-success">
                    <div class="card-body">
                        <h3 class="card-title text-success">Book Appointment</h3>
                        <p class="card-text text-muted">Schedule a new appointment with a physician</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>