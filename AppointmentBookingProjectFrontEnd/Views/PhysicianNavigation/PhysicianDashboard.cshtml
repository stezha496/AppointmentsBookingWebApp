@{
    ViewData["Title"] = "Physician Dashboard";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2>Physician Dashboard</h2>
        <p class="text-muted">
            Welcome, <strong>@Context.Session.GetString("UserName")</strong>
        </p>
    </div>

    <div class="row">
        <div class="col-md-4">
            <a asp-controller="PhysicianNavigation"
                   asp-action="PhysicianUpcomingAppointments"
                   class="text-decoration-none">
                <div class="card shadow-sm h-100 border-primary">
                    <div class="card-body">
                        <h3 class="card-title text-primary">View My Upcoming Appointments</h3>
                        <p class="card-text text-muted">
                            See all your scheduled upcoming patient appointments
                        </p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>
